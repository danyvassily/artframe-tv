{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "artworks.json", "use": "@vercel/static" },
    { "src": "config.example.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/artworks.json$", "dest": "/artworks.json" },
    { "src": "^/config.example.js$", "dest": "/config.example.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "artworks.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "index.html",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src * 'unsafe-inline' 'unsafe-eval'; img-src * data: blob:; connect-src *;" }
      ]
    }
  ]
}
