{
  "version": 2,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "^/frames/(.*\\.png)$", "dest": "/frames/$1" },
    { "src": "^/artworks.json$", "dest": "/artworks.json" },
    { "src": "/(.*\\.(png|jpg|jpeg|gif|svg|ico|woff2?|css|js|json))$", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "artworks.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "frames/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "index.html",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src * 'unsafe-inline' 'unsafe-eval'; img-src * data: blob:; connect-src *;" }
      ]
    }
  ]
}
